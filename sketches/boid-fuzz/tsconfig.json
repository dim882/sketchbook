{
  "extends": "@dim882/sketchlib/presets/default/tsconfig.json",
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false
  }
}
